# Normalize line endings to LF on checkin.
* text=auto eol=lf

*.py    text diff=python
*.md    text
*.yaml  text
*.yml   text
*.toml  text
*.cfg   text
*.txt   text

# Treat notebooks as text but keep diffs compact.
*.ipynb text

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.wav   binary
*.flac  binary
